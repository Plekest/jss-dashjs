# Jspreadsheet Pro licence certificate (single key for grid + formula-pro).
# When set, the app boots in "pro mode": /sheets gets the full editor
# (toolbar, formula bar, tabs) and dashjs calculated fields evaluate for real.
# When absent, everything runs in the current simple/evaluation mode.
VITE_JSS_LICENSE=

# Auth: secret used to sign the session cookie. Set a long random value in production.
SESSION_SECRET=

# Email (Resend) — used for member invites and password reset links.
RESEND_API_KEY=
EMAIL_FROM=JSS Dashjs <onboarding@resend.dev>

# Base URL of the frontend, used to build invite/reset links sent by email.
APP_URL=http://localhost:5173
